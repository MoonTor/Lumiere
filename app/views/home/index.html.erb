<!-- app/views/home/index.html.erb -->
<div class="min-h-screen w-full bg-stone-50 text-neutral-900">
  <!-- Navbar -->
  <%= render "shared/navbar" %>
  <!-- Hero Section -->
  <section
    class="w-full min-h-[720px] bg-cover bg-center bg-no-repeat"
    style="background-image:
      linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)),
      url('<%= asset_path("Living-Room.jpg") %>');">
    <div class="mx-auto flex min-h-[720px] max-w-[1600px] items-center px-8 py-20 xl:px-12">
      <div class="max-w-3xl text-white">
        <p class="mb-4 text-sm uppercase tracking-[0.3em] text-white/80">
          Modern Interiors, Timeless Comfort
        </p>
        <h2 class="text-5xl font-semibold leading-tight md:text-6xl xl:text-7xl">
          Furniture curated for calm, elegant living.
        </h2>
        <p class="mt-6 max-w-xl text-lg leading-8 text-white/80">
          Discover refined pieces for living rooms, bedrooms, and workspaces —
          designed to bring warmth, simplicity, and balance into your home.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <%= link_to "Shop Collection", products_path,
    class: "rounded-full border border-white px-8 py-3 text-sm font-medium text-white transition-colors hover:bg-white hover:text-neutral-900" %>
        </div>
      </div>
    </div>
  </section>
  <!-- Categories Section -->
  <section class="mx-auto max-w-[1600px] px-8 py-16 xl:px-12">
    <div class="mb-8 flex items-end justify-between">
      <div>
        <p class="text-sm uppercase tracking-[0.3em] text-neutral-500">Categories</p>
        <h3 class="mt-2 text-3xl font-semibold">Shop by category</h3>
      </div>
      <%= link_to "View all", products_path, class: "text-sm text-neutral-500 hover:text-neutral-800" %>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      <%= link_to products_path(category: "sofa"), class: "block rounded-3xl bg-white p-6 shadow-sm ring-1 ring-neutral-200 transition hover:-translate-y-1 hover:shadow-md" do %>
        <div class="mb-4 flex h-56 items-center justify-center overflow-hidden rounded-2xl bg-stone-100 text-neutral-500">
          <%= image_tag "Living-Set-Home1.jpg", alt: "Living-Set", class: "h-full w-full object-cover" %>
        </div>
        <h4 class="text-xl font-medium">Living Room</h4>
        <p class="mt-2 text-sm leading-6 text-neutral-600">
          Browse a mix of vintage and modern sofas and couches
        </p>
      <% end %>
      <%= link_to products_path(category: "table"), class: "block rounded-3xl bg-white p-6 shadow-sm ring-1 ring-neutral-200 transition hover:-translate-y-1 hover:shadow-md" do %>
        <div class="mb-4 flex h-56 items-center justify-center overflow-hidden rounded-2xl bg-stone-100 text-neutral-500">
          <%= image_tag "Dining-Set-Home1.jpg", alt: "Dining Set", class: "h-full w-full object-cover" %>
        </div>
        <h4 class="text-xl font-medium">Dining Sets</h4>
        <p class="mt-2 text-sm leading-6 text-neutral-600">
          Browse different table and dining room sets ranging from breakfeast nooks to family feasts
        </p>
      <% end %>
      <%= link_to products_path(category: "bed"), class: "block rounded-3xl bg-white p-6 shadow-sm ring-1 ring-neutral-200 transition hover:-translate-y-1 hover:shadow-md" do %>
        <div class="mb-4 flex h-56 items-center justify-center overflow-hidden rounded-2xl bg-stone-100 text-neutral-500">
          <%= image_tag "Bedroom-Set-Home1.jpg", alt: "Bedroom-Set", class: "h-full w-full object-cover" %>
        </div>
        <h4 class="text-xl font-medium">Bedsets</h4>
        <p class="mt-2 text-sm leading-6 text-neutral-600">
          Peruse different betsets and frames for you room to give it that personal touch
        </p>
      <% end %>
      <%= link_to products_path(category: "chair"), class: "block rounded-3xl bg-white p-6 shadow-sm ring-1 ring-neutral-200 transition hover:-translate-y-1 hover:shadow-md" do %>
        <div class="mb-4 flex h-56 items-center justify-center overflow-hidden rounded-2xl bg-stone-100 text-neutral-500">
          <%= image_tag "Chair-Set-Home1.jpg", alt: "Chair-Set", class: "h-full w-full object-cover" %>
        </div>
        <h4 class="text-xl font-medium">Chairs</h4>
        <p class="mt-2 text-sm leading-6 text-neutral-600">
          Your pick of recliners or classy chairs for any room in your house
        </p>
      <% end %>
    </div>
  </section>
</div>
