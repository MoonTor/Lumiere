<!-- app/views/devise/shared/_links.html.erb -->

<div class="flex flex-wrap gap-4">
  <% if controller_name != 'sessions' %>
    <%= link_to "Log in", new_session_path(resource_name), class: "hover:text-neutral-900" %>
  <% end %>

  <% if controller_name != 'registrations' %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "hover:text-neutral-900" %>
  <% end %>

  <!-- <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Forgot your password?", new_password_path(resource_name), class: "hover:text-neutral-900" %>
  <% end %> -->
</div>
