<!-- app/views/products/show.html.erb -->
<!-- Navbar -->
<%= render "shared/navbar" %>
<!-- Main Product Section -->
<div class="min-h-screen bg-stone-50 px-8 py-16 text-neutral-900 xl:px-12">
  <div class="mx-auto grid max-w-[1600px] gap-16 lg:grid-cols-2">
    <!-- LEFT SIDE: Product Image -->
    <div class="overflow-hidden rounded-[2rem] bg-white shadow-sm ring-1 ring-neutral-200">
      <% if @product.image.attached? %>
        <%= image_tag @product.image, class: "h-full w-full object-cover" %>
      <% end %>
    </div>
    <!-- RIGHT SIDE: Product Information -->
    <div class="flex flex-col justify-center">
      <!-- Product category label -->
      <p class="text-sm uppercase tracking-[0.3em] text-neutral-500">
        <%= @product.category.capitalize %>
      </p>
      <!-- Product title -->
      <h1 class="mt-4 text-5xl font-semibold tracking-tight">
        <%= @product.name %>
      </h1>
      <!-- Product price -->
      <p class="mt-6 text-3xl font-semibold">
        $<%= "%.2f" % @product.price %>
      </p>
      <!-- Product color -->
      <p class="mt-4 text-lg text-neutral-600">
        Color: <span class="font-medium text-neutral-900"><%= @product.color %></span>
      </p>
      <!-- Stock status -->
      <p class="mt-3 text-lg text-neutral-600">
        Stock: <span class="font-medium text-neutral-900"><%= @product.stock %> available</span>
      </p>
      <!-- Product description -->
      <div class="mt-8 border-t border-neutral-200 pt-8">
        <h2 class="text-lg font-medium">Description</h2>
        <p class="mt-4 text-lg leading-8 text-neutral-600">
          <%= @product.description %>
        </p>
      </div>
      <!-- CTA buttons -->
      <div class="mt-10 flex gap-4">
        <!-- Add to cart button -->
        <% if @product.stock > 0 %>
          <%= button_to "Add to Cart",
      cart_items_path(product_id: @product.id),
      method: :post,
      class: "rounded-full bg-neutral-900 px-8 py-4 text-sm font-medium text-white transition hover:bg-neutral-700" %>
        <% else %>
          <button disabled class="rounded-full bg-neutral-300 px-8 py-4 text-sm font-medium text-white cursor-not-allowed">
            Out of Stock
          </button>
        <% end %>
        <!-- Back to products -->
        <%= link_to "Back to Products", products_path,
            class: "rounded-full bg-white px-8 py-4 text-sm font-medium text-neutral-900 ring-1 ring-neutral-200 transition hover:bg-neutral-100" %>
      </div>
    </div>
  </div>
  <!-- Reviews Section -->
  <div class="mt-16 border-t border-neutral-200 pt-10">
    <h2 class="text-2xl font-semibold mb-6">Customer Reviews</h2>
    <!-- Review Form Section -->
    <% if user_signed_in? %>
      <div class="mt-10 rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-neutral-200">
        <h3 class="text-2xl font-semibold">Write a Review</h3>
        <p class="mt-2 text-neutral-600">
          Share your thoughts about this product.
        </p>
        <%= form_with model: [@product, @review], local: true, class: "mt-6 space-y-6" do |f| %>
          <!-- Rating field -->
          <div>
            <%= f.label "Rating (1-5)", class: "mb-2 block text-sm font-medium text-neutral-700" %>
            <%= f.number_field :rating, min: 1, max: 5,
            class: "w-full rounded-2xl border border-neutral-300 bg-white px-4 py-3 text-base text-neutral-900 outline-none transition focus:border-neutral-500" %>
          </div>
          <!-- Comment field -->
          <div>
            <%= f.label :comment, class: "mb-2 block text-sm font-medium text-neutral-700" %>
            <%= f.text_area :comment, rows: 5,
            class: "w-full rounded-2xl border border-neutral-300 bg-white px-4 py-3 text-base text-neutral-900 outline-none transition focus:border-neutral-500" %>
          </div>
          <!-- Submit button -->
          <div>
            <%= f.submit "Submit Review",
    class: "rounded-full bg-neutral-900 px-8 py-4 text-sm font-medium text-white transition hover:bg-neutral-700 cursor-pointer",
    data: { disable_with: "Submitting..." } %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-10 rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-neutral-200">
        <p class="text-neutral-600">
          Please
          <%= link_to "log in", new_user_session_path, class: "font-medium text-neutral-900 hover:text-neutral-500" %>
          to write a review.
        </p>
      </div>
    <% end %>
    <% if @product.reviews.any? %>
      <% @product.reviews.each do |review| %>
        <div class="mb-6 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-neutral-200">
          <p class="text-sm text-neutral-500">
            <%= review.user.email %>
          </p>
          <p class="mt-2 text-lg font-medium">
            Rating: <%= review.rating %>/5
          </p>
          <p class="mt-2 text-neutral-700">
            <%= review.comment %>
          </p>
        </div>
      <% end %>
    <% else %>
      <div class="mb-6 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-neutral-200">
        <p class="text-neutral-600">
          No reviews yet. Be the first to share your thoughts.
        </p>
      </div>
    <% end %>